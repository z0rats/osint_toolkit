# Copy this file to `.env` and adjust as needed. Every value below has a
# working default (see backend/app/core/config/settings.py) - you only need
# to set the ones you actually want to change. Third-party API keys
# (VirusTotal, Shodan, etc.) are NOT configured here - they're managed from
# the app's own Settings UI and stored (encrypted) in the database.

# --- Docker Compose (host-side, not read by the app itself) ---
# Host port the frontend is published on. Change this if 4000 is taken, or if
# you're running this stack alongside another corvid instance (e.g. a local
# dev build next to a docker-compose.prod.yaml deployment) on the same host.
FRONTEND_PORT=4000

# --- App ---
ENVIRONMENT=development
DATA_DIR=data
STATIC_DIR=app/static
# Below this much free space on the data_dir mount, healthcheck/startup report
# "low" disk status instead of "healthy". Lower this on deployments that
# legitimately run close to the edge (e.g. a small VPS).
LOW_DISK_SPACE_THRESHOLD_BYTES=1073741824

# --- Database (DB_) ---
DB_URL=sqlite:///./data/corvid.db
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# --- Logging (LOG_) ---
LOG_LEVEL=INFO
LOG_DIR=data/logs
LOG_APP_NAME=corvid
LOG_MAX_FILE_SIZE=10485760
LOG_BACKUP_COUNT=5
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true

# --- API (API_) ---
API_TITLE=Corvid
API_VERSION=2.0.0
API_DEBUG=false
API_MAX_REQUEST_BODY_BYTES=52428800
# JSON array syntax - only needed if you're not using the default nginx setup on :4000
API_CORS_ORIGINS=["http://localhost:3000"]
API_TRUSTED_HOSTS=["localhost","127.0.0.1"]
# Required to use the app (see README's "Access token" section). Leave empty
# to auto-generate one on first startup, persisted to <DATA_DIR>/.access_token.
# Set your own here instead if you want a stable, portable value.
API_ACCESS_TOKEN=

# --- Security (SECURITY_) ---
# Dev/testing only - allows SSRF-guarded requests to target private/loopback/
# link-local addresses. Never enable this if the app is reachable by anyone
# you don't trust.
SECURITY_ALLOW_PRIVATE_NETWORK_TARGETS=false
# Encrypts API keys at rest in the database. Leave empty to auto-generate one
# on first startup, persisted to <DATA_DIR>/.encryption_key (back it up
# together with the database - losing it makes stored keys unrecoverable).
# Set your own here instead if you want a stable, portable value.
SECURITY_ENCRYPTION_KEY=

# --- Scheduler (SCHEDULER_) ---
SCHEDULER_DEFAULT_FETCH_INTERVAL=30
SCHEDULER_MAX_JOB_INSTANCES=1
SCHEDULER_BLACKLIST_REFRESH_INTERVAL_HOURS=24
